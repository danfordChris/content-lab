# The app runs fully WITHOUT any keys (local JSON storage, no login, text falls
# back to a built-in generator). Add the sections below to switch on real services.

# ── DATA + AUTH (Firebase — free Spark tier) ─────────────────────────────────
# Leave ALL of these blank to keep the local no-login store.
# Set them to use Firestore (cloud persistence) + Firebase Auth (login).
#
# Client config — Firebase console → Project settings → Your apps → Web app.
# These are public (safe to expose).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
#
# Server config — Firebase console → Project settings → Service accounts →
# "Generate new private key". Keep the private key SECRET. In the .env, keep the
# key on one line with literal \n for newlines (the app converts them back).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
#
# Alternative to the two lines above (gcloud / FlutterFire style): save the
# service-account JSON and point to it instead.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
#
# Tip: run `npm run firebase:configure` to auto-fill the NEXT_PUBLIC_* values.


# ── TEXT (ideas, posts, scripts, carousels) ──────────────────────────────────
# Any OpenAI-compatible endpoint. Pick ONE setup:
#
# FREE — Google Gemini (recommended). Get a free key: https://aistudio.google.com/apikey
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_API_KEY=
OPENAI_MODEL=gemini-2.5-flash
#
# Or PAID — OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── IMAGES (carousel slides + cover images) ──────────────────────────────────
# "auto" picks the best configured provider, then falls back. Or force one:
# cloudflare | together | pollinations | openai
IMAGE_PROVIDER=auto
#
# RECOMMENDED FREE — Cloudflare Workers AI (FLUX-1-schnell). No card, no deposit.
#   1) Free account: https://dash.cloudflare.com/sign-up
#   2) Account ID:   Workers & Pages → Overview (right sidebar / URL)
#   3) API token:    My Profile → API Tokens → Create Token → "Workers AI" template
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
#
# Together AI (FLUX.1-schnell-Free) — NOTE: now requires an initial account
# deposit before the API activates. Leave blank unless you've funded it.
TOGETHER_API_KEY=
#
# Pollinations — keyless but its anonymous tier is heavily rate-limited (often
# fails behind shared/cloud IPs). Free token (no card): https://auth.pollinations.ai
POLLINATIONS_TOKEN=
#
# Paid OpenAI images (only when IMAGE_PROVIDER=openai).
# gpt-image-1 needs a verified OpenAI org; otherwise use: dall-e-3
OPENAI_IMAGE_MODEL=gpt-image-1

# ── Reminders (Gmail SMTP + Vercel Cron) ──────────────────────────────────────
# Gmail app password: myaccount.google.com/apppasswords (requires 2FA)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Random string; Vercel Cron calls /api/cron/* with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
APP_URL=https://contentlab.danfordchris.dev
