rules_version = '2';

// Content Lab — each user's whole dataset lives in contentlab/{userId}.
// The Next.js server uses the Admin SDK (bypasses these rules), but these lock
// down any direct client access (e.g. a FlutterFire app on the same project).
service cloud.firestore {
  match /databases/{database}/documents {
    match /contentlab/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
